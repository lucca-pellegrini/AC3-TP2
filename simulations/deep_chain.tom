# NOTE: This simulation file was written with help from LLMs

# Very deep dependency chain with alternating operations.
#
# A chain of 12 instructions where each depends on the previous one,
# alternating between ADD, MUL, SUB, and DIV. This tests the simulator's
# ability to handle long dependency chains and exercise all FP units.
#
# Starting with F0 = 2.0:
#   F1  = F0  + 1 = 3
#   F2  = F1  * 2 = 6
#   F3  = F2  - 1 = 5
#   F4  = F3  / 1 = 5 (identity div)
#   F5  = F4  + 2 = 7
#   F6  = F5  * 3 = 21
#   F7  = F6  - 5 = 16
#   F8  = F7  / 2 = 8
#   F9  = F8  + 4 = 12
#   F10 = F9  * 2 = 24
#   F11 = F10 - 8 = 16
#   F12 = F11 / 4 = 4

cycles {
    add.d  = 2
    sub.d  = 2
    mult.d = 4
    div.d  = 12
}

units {
    add.d  = 1
    mult.d = 1
}

registers {
    F0 = 2.0
    # Constants for operations
    F20 = 1.0
    F21 = 2.0
    F22 = 3.0
    F23 = 4.0
    F24 = 5.0
    F25 = 8.0
}

instructions {
    ADD.D F1  F0  F20   # 2 + 1 = 3
    MUL.D F2  F1  F21   # 3 * 2 = 6
    SUB.D F3  F2  F20   # 6 - 1 = 5
    DIV.D F4  F3  F20   # 5 / 1 = 5
    ADD.D F5  F4  F21   # 5 + 2 = 7
    MUL.D F6  F5  F22   # 7 * 3 = 21
    SUB.D F7  F6  F24   # 21 - 5 = 16
    DIV.D F8  F7  F21   # 16 / 2 = 8
    ADD.D F9  F8  F23   # 8 + 4 = 12
    MUL.D F10 F9  F21   # 12 * 2 = 24
    SUB.D F11 F10 F25   # 24 - 8 = 16
    DIV.D F12 F11 F23   # 16 / 4 = 4
}
