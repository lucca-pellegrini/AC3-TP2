# NOTE: This test file was written with help from LLMs

# Vector dot product: A · B = sum(A[i] * B[i])
#
# Compute dot product of two 4-element vectors:
#   A = [2, 3, 4, 5]  in F0-F3
#   B = [1, 2, 3, 4]  in F4-F7
#
# Steps:
#   F8  = A[0] * B[0] = 2 * 1 = 2
#   F9  = A[1] * B[1] = 3 * 2 = 6
#   F10 = A[2] * B[2] = 4 * 3 = 12
#   F11 = A[3] * B[3] = 5 * 4 = 20
#
# Then reduce (tree-style for parallelism):
#   F12 = F8  + F9  = 2 + 6 = 8
#   F13 = F10 + F11 = 12 + 20 = 32
#   F14 = F12 + F13 = 8 + 32 = 40  <-- final result
#
# The 4 multiplies can execute in parallel on the Mul units.
# The tree reduction allows some add parallelism too.

cycles {
    add.d  = 2
    mult.d = 4
}

units {
    add.d  = 2
    mult.d = 2
}

registers {
    # Vector A
    F0 = 2.0
    F1 = 3.0
    F2 = 4.0
    F3 = 5.0
    # Vector B
    F4 = 1.0
    F5 = 2.0
    F6 = 3.0
    F7 = 4.0
}

instructions {
    # Element-wise multiply (can run in parallel)
    MUL.D F8  F0 F4      # A[0] * B[0] = 2
    MUL.D F9  F1 F5      # A[1] * B[1] = 6
    MUL.D F10 F2 F6      # A[2] * B[2] = 12
    MUL.D F11 F3 F7      # A[3] * B[3] = 20
    # Tree reduction
    ADD.D F12 F8  F9     # 2 + 6 = 8
    ADD.D F13 F10 F11    # 12 + 20 = 32 (parallel with above)
    ADD.D F14 F12 F13    # 8 + 32 = 40  (final dot product)
}
