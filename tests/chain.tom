cycles {
    add.d  = 2
    mult.d = 4
}

units {
    add.d  = 1
    mult.d = 1
}

registers {
    F2 = 1.0
    F3 = 2.0
    F5 = 3.0
    F7 = 4.0
    F9 = 5.0
}

instructions {
    ADDD  F1 F2 F3    # F1 = F2 + F3 = 3
    MULTD F4 F1 F5    # F4 = F1 * F5 = 9  (depends on F1)
    ADDD  F6 F4 F7    # F6 = F4 + F7 = 13 (depends on F4)
    MULTD F8 F6 F9    # F8 = F6 * F9 = 65 (depends on F6)
}
