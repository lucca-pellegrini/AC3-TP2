cycles {
    ADD.D  = 2
    SUB.D  = 2
    MULT.D = 4
    DIV.D  = 10
}

units {
    ADD.D  = 1
    MULT.D = 1
}

registers {
    F4 = 2.0
    F6 = 10.0
}

instructions {
    ADDD  F8  F4  F6    # F8 = 2 + 10 = 12
    MULTD F10 F8  F8    # F10 = 12 * 12 = 144
    SUBD  F12 F10 F4    # F12 = 144 - 2 = 142
}
